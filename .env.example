APP_TITLE=Solar Monitor
DATABASE_PATH=data/solar_monitor.db
TIMEZONE=Australia/Melbourne
POLLER_ONLY=false
BLE_SITE_ONLY=false

BLE_ENABLED=true
BLE_MAC=C9:91:09:7A:2C:B9
BLE_PAIRING_CODE=774034
BLE_READING_BATCH_SIZE_MINUTES=1
BLE_PULSES_PER_KWH=800
BLE_RETRY_DELAY_SECONDS=5
BLE_CONNECTION_TIMEOUT_SECONDS=30
BLE_ZERO_AFTER_MINUTES=10
REMOTE_INGEST_URL=
REMOTE_INGEST_TOKEN=
INGEST_TOKEN=
NETWORK_BLE_ENABLED=false
NETWORK_BLE_URL=
NETWORK_BLE_TIMEOUT_SECONDS=10
NETWORK_BLE_POLL_SECONDS=15
NETWORK_BLE_USAGE_LINE_INDEX=0
NETWORK_BLE_BATTERY_LINE_INDEX=1
NETWORK_BLE_TIMESTAMP_LINE_INDEX=2
NETWORK_BLE_STATE_LINE_INDEX=3
BLE_SITE_HOST=0.0.0.0
BLE_SITE_PORT=8002

LOCAL_SITE_ENABLED=true
LOCAL_SITE_URL=http://192.168.1.228/home.cgi
LOCAL_SITE_TIMEOUT_SECONDS=10
LOCAL_SITE_POLL_SECONDS=15
LOCAL_SITE_FORMAT=auto
LOCAL_USAGE_JSON_PATH=
LOCAL_SOLAR_JSON_PATH=
LOCAL_USAGE_REGEX=
LOCAL_SOLAR_REGEX=
LOCAL_USAGE_LINE_INDEX=
LOCAL_SOLAR_LINE_INDEX=10
LOCAL_USAGE_DIVISOR=1
LOCAL_SOLAR_DIVISOR=60
LOCAL_USAGE_MULTIPLIER=1
LOCAL_SOLAR_MULTIPLIER=1
LOCAL_SITE_ZERO_ON_ERROR=true
LOCAL_SITE_404_AVERAGE_WINDOW=5
LOCAL_SITE_404_ZERO_AFTER_MINUTES=10
LOCAL_SITE_CONNECTION_ZERO_AFTER_MINUTES=10
FAILURE_AVERAGE_WINDOW=3

BYD_ENABLED=false
BYD_NODE_BIN=node
BYD_RE_DIR=/opt/byd-re
BYD_USERNAME=
BYD_PASSWORD=
BYD_BASE_URL=https://dilinkappoversea-eu.byd.auto
BYD_COUNTRY_CODE=AU
BYD_LANGUAGE=en
BYD_TIME_ZONE=Australia/Melbourne
BYD_VIN=
BYD_POLL_SECONDS=60
BYD_COMMAND_TIMEOUT_SECONDS=120

TUYA_ENABLED=false
TUYA_BASE_URL=https://openapi.tuyaeu.com
# Tuya Cloud project client ID / access ID
TUYA_ACCESS_ID=
# Tuya Cloud project client secret / access secret
TUYA_ACCESS_SECRET=
# Charger device id from Tuya Cloud device list. Do not use the project code here.
TUYA_DEVICE_ID=
TUYA_POLL_SECONDS=30
TUYA_TIMEOUT_SECONDS=15
# Status/function codes for the charger datapoints
TUYA_VOLTAGE_CODE=107
TUYA_CURRENT_CODE=108
TUYA_POWER_CODE=power_total
TUYA_TEMPERATURE_CODE=110
TUYA_SESSION_ENERGY_CODE=charge_energy_once
TUYA_VOLTAGE_DIVISOR=10
TUYA_CURRENT_DIVISOR=10
TUYA_POWER_DIVISOR=100
TUYA_TEMPERATURE_DIVISOR=10
TUYA_SESSION_ENERGY_DIVISOR=100
# Enable solar-surplus charging automation outside off-peak hours only.
# Off-peak can force charging on regardless of solar/guard thresholds, then force it off at the end.
TUYA_SOLAR_AUTOMATION_ENABLED=false
TUYA_SOLAR_AUTOMATION_POLL_SECONDS=30
TUYA_SOLAR_AUTOMATION_WINDOW_MINUTES=5
TUYA_SOLAR_AUTOMATION_6A_WATTS=2000
TUYA_SOLAR_AUTOMATION_10A_WATTS=3000
TUYA_SOLAR_AUTOMATION_13A_WATTS=4000
TUYA_OFFPEAK_CHARGE_ENABLED=true
TUYA_OFFPEAK_START_HOUR=0
TUYA_OFFPEAK_END_HOUR=6
# If BLE grid import stays above this threshold for the full window, force charging off
# and keep it off for at least the cooldown period.
TUYA_BLE_GUARD_WATTS=2000
TUYA_BLE_GUARD_WINDOW_MINUTES=15
TUYA_BLE_GUARD_COOLDOWN_MINUTES=30

API_DEFAULT_HOURS=24
API_MAX_POINTS=5000
